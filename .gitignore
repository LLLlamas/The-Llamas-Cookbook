# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# macOS
.DS_Store

# iOS signing material — these contain private keys and must NEVER be committed.
*.p8
*.p12
*.mobileprovision
*.key
*.jks
*.pem
credentials.json
credentials/

# Xcode build output (the real Xcode project is generated by XcodeGen; see
# ios-native/.gitignore for the ios-native/ specifics).
build/
DerivedData/
.build/
xcuserdata/
*.xcuserstate
Packages/
Package.resolved

# Environment overrides
.env
.env*.local

# Leftover Expo / React Native artifacts on disk (the RN source itself lives
# in outdated/rn-expo/ and is tracked). These directories can be deleted once
# Lorenzo no longer needs to run `npm install` in the archived folder.
node_modules/
.expo/
dist/
web-build/
expo-env.d.ts
*.tsbuildinfo
.metro-health-check*
npm-debug.*
yarn-debug.*
yarn-error.*
